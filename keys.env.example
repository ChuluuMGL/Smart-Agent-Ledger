# Smart Agent Ledger key configuration example.
# Copy this file to keys.env, fill in real keys, and keep keys.env private.
# keys.env is ignored by git. Do not put real keys in this example file.

# ---------- DeepSeek ----------
# Optional. If token-to-key routing is not needed, fill only DEEPSEEK_API_KEY.
DEEPSEEK_API_KEY=

# Optional named keys for local routing experiments.
DEEPSEEK_KEY_CODING_AGENT_MAIN=
DEEPSEEK_KEY_CODING_AGENT_LAPTOP=

# ---------- GLM ----------
GLM_API_KEY=

# Optional named keys for local routing experiments.
GLM_KEY_CODING_AGENT_MAIN=
GLM_KEY_ALT_AGENT_MAIN=
GLM_KEY_CODING_AGENT_LAPTOP=
GLM_KEY_ALT_AGENT_LAPTOP=

# ---------- Qwen ----------
QWEN_API_KEY=

# ---------- API authentication ----------
# When set, all endpoints except /health require X-API-Key unless the client IP
# is allowlisted. Leave blank only for local-only development.
GATEWAY_API_KEY=
